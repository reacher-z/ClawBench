FROM --platform=linux/amd64 clawbench-base:amd64

# --- Microsoft Edge ----------------------------------------------------------
# The Claude in Chrome extension is officially supported on Google Chrome and
# Microsoft Edge (https://code.claude.com/docs/en/chrome). We use Edge because
# Google Chrome 147+ compiles a hard refusal of `--load-extension` into the
# branded binary.
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget gnupg ca-certificates unzip \
    && wget -qO- https://packages.microsoft.com/keys/microsoft.asc \
    | gpg --dearmor -o /usr/share/keyrings/microsoft.gpg \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/edge stable main" \
    > /etc/apt/sources.list.d/edge.list \
    && apt-get update && apt-get install -y --no-install-recommends microsoft-edge-stable \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# --- Claude Code CLI + LiteLLM ----------------------------------------------
RUN PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 npm install -g @anthropic-ai/claude-code@2.1.110
RUN pip install --no-cache-dir 'litellm[proxy]==1.83.9'

# --- cli.js bypass patches --------------------------------------------------
# Rewrite subscription / interactivity / auth / bridge-URL gates inside the
# bundled CLI so --chrome works against LiteLLM-routed providers without an
# Anthropic subscription.
RUN python3 - /usr/local/lib/node_modules/@anthropic-ai/claude-code/cli.js <<'PYEOF'
import re, sys
path = sys.argv[1]
src = open(path).read()
patches: list[str] = []

def sub_regex(label, pat, rep):
    global src
    new = re.sub(pat, rep, src, count=1)
    if new == src:
        raise SystemExit(f"ERROR: {label} regex did not match")
    src = new
    patches.append(label)

def sub_literal(label, needle, repl):
    global src
    if needle not in src:
        raise SystemExit(f"ERROR: {label} literal not found")
    src = src.replace(needle, repl, 1)
    patches.append(label)

# 1. i7() = isClaudeAISubscriber. Gates claude-in-chrome skill + MCP server
# registration.
sub_regex(
    "i7()",
    r"function i7\(\)\{if\(!qX\(\)\)return!1;return yb\(o7\(\)\?\.scopes\)\}",
    "function i7(){return!0}",
)
# 2. OV() = isInteractive getter. Yu6() = OV() && GnY() && I8(...). In -p
# piped mode stdout is not a TTY so OV() is false and --chrome is gated off.
# Force true so the MCP registers regardless.
sub_regex(
    "OV()",
    r"function OV\(\)\{return m8\.isInteractive\}",
    "function OV(){return!0}",
)
# 3. SDK validateHeaders throws an Error whose message contains "x-api-key"
# when it thinks the auth header is missing — short-circuiting the first
# turn before ANTHROPIC_BASE_URL is ever contacted. Make it a no-op.
sub_literal(
    "validateHeaders()",
    'validateHeaders({values:q,nulls:K}){if(q.get("x-api-key")||q.get("authorization"))return;',
    'validateHeaders({values:q,nulls:K}){return;if(q.get("x-api-key")||q.get("authorization"))return;',
)
# 4. Point every hardcoded api.anthropic.com reference at the local mock on
# :4001 (ANTHROPIC_BASE_URL already handles /v1/messages on :4000 via LiteLLM).
antro_count = src.count("https://api.anthropic.com")
if antro_count == 0:
    raise SystemExit("ERROR: no api.anthropic.com references found")
src = src.replace("https://api.anthropic.com", "http://127.0.0.1:4001")
patches.append(f"api.anthropic.com x{antro_count}")
# 5. Redirect the session bridge WebSocket to the local fake on :4002.
# `ws://localhost:8765` is what keY() returns when LOCAL_BRIDGE=1 — we set
# that env var at runtime to flip NeY() → true so the CLI skips OAuth.
bridge_patches = 0
for needle in ("wss://bridge.claudeusercontent.com",
               "wss://bridge-staging.claudeusercontent.com",
               "ws://localhost:8765"):
    if needle in src:
        src = src.replace(needle, "ws://127.0.0.1:4002", 1)
        bridge_patches += 1
patches.append(f"bridge URL x{bridge_patches}")
open(path, "w").write(src)
PYEOF

# --- Mock Anthropic meta API -----------------------------------------------
# Served on :4001 at runtime; cli.js has been rewritten above so every
# hardcoded Anthropic meta endpoint (profile/bootstrap/organizations/etc.)
# lands here instead of Anthropic's cloud.
COPY src/harnesses/claude-code-chrome-extension/mock-anthropic-api.py /usr/local/bin/mock-anthropic-api.py
RUN chmod +x /usr/local/bin/mock-anthropic-api.py

# --- Fake Anthropic session bridge -----------------------------------------
# Local stand-in for wss://bridge.claudeusercontent.com/chrome/<user>. Both
# the CLI (after the build-time URL rewrite above) and the extension (after
# the build-time patch below) connect here at runtime; we pair them and
# relay tool_call / tool_result / ping / permission_request frames.
RUN pip install --no-cache-dir 'websockets==13.1' \
    && cat > /usr/local/bin/fake-anthropic-bridge.py <<'EOF'
#!/usr/bin/env python3
"""Local stand-in for wss://bridge.claudeusercontent.com/chrome/<user>."""
from __future__ import annotations
import asyncio, json, logging, sys, uuid
from typing import Any, Dict, Optional
import websockets

logging.basicConfig(level=logging.INFO, format="[bridge] %(message)s")
log = logging.getLogger("bridge")
logging.getLogger("websockets").setLevel(logging.WARNING)


class Peer:
    __slots__ = ("ws", "client_type", "device_id", "name")

    def __init__(self, ws, client_type, device_id, name):
        self.ws = ws
        self.client_type = client_type
        self.device_id = device_id
        self.name = name


peers: Dict[str, Peer] = {}


def is_extension(p):
    return "extension" in (p.client_type or "").lower()


def is_cli(p):
    return not is_extension(p)


async def broadcast(message, filter_fn):
    for peer in list(peers.values()):
        if filter_fn(peer):
            try:
                await peer.ws.send(json.dumps(message))
            except Exception:
                pass


async def handle(ws):
    my: Optional[Peer] = None
    try:
        async for raw in ws:
            try:
                msg = json.loads(raw)
            except Exception:
                log.warning("non-json frame: %r", raw[:80])
                continue
            kind = msg.get("type")
            if kind == "connect":
                client_type = msg.get("client_type", "unknown")
                device_id = msg.get("device_id") or f"{client_type}-{uuid.uuid4().hex[:8]}"
                name = msg.get("name") or f"ClawBench {client_type}"
                my = Peer(ws, client_type, device_id, name)
                peers[device_id] = my
                counterparts = [p for p in peers.values() if p is not my and (
                    is_extension(p) if is_cli(my) else is_cli(p))]
                status = "paired" if counterparts else "waiting"
                await ws.send(json.dumps({"type": status}))
                log.info("%s connected as %s (%s) -> %s",
                         client_type, device_id[:8], name, status)
                await broadcast({"type": "peer_connected", "deviceId": device_id},
                                lambda p: p is not my)
            elif kind == "ping":
                await ws.send(json.dumps({"type": "pong"}))
            elif kind == "list_extensions":
                exts = [{
                    "deviceId": p.device_id, "name": p.name,
                    "connectedAt": 0, "osPlatform": "Linux",
                } for p in peers.values() if is_extension(p)]
                await ws.send(json.dumps({"type": "extensions_list", "extensions": exts}))
            elif kind == "pairing_request":
                req_id = msg.get("request_id")
                ext = next((p for p in peers.values() if is_extension(p)), None)
                if ext:
                    await ws.send(json.dumps({
                        "type": "pairing_response", "request_id": req_id,
                        "device_id": ext.device_id, "name": ext.name,
                    }))
            elif kind == "tool_call":
                target_id = msg.get("target_device_id")
                target = peers.get(target_id) if target_id else next(
                    (p for p in peers.values() if is_extension(p)), None)
                if target:
                    await target.ws.send(raw)
            elif kind in ("tool_result", "permission_request", "permission_response",
                          "notification", "error"):
                if my is None:
                    continue
                await broadcast(msg, lambda p: p is not my and (
                    is_extension(p) if is_cli(my) else is_cli(p)))
            else:
                log.debug("relay unknown type=%r", kind)
                if my is not None:
                    await broadcast(msg, lambda p: p is not my)
    except websockets.ConnectionClosed:
        pass
    except Exception as e:
        log.warning("handler error: %s", e)
    finally:
        if my and peers.get(my.device_id) is my:
            peers.pop(my.device_id, None)
            await broadcast({"type": "peer_disconnected", "deviceId": my.device_id},
                            lambda p: True)
            log.info("disconnected %s", my.device_id[:8])


async def main():
    host, port = "127.0.0.1", 4002
    log.info("listening on ws://%s:%d/", host, port)
    async with websockets.serve(handle, host, port, max_size=None):
        await asyncio.Future()


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        sys.exit(0)
EOF
RUN chmod +x /usr/local/bin/fake-anthropic-bridge.py

# --- Unpack the Claude in Chrome extension from the Web Store ---------------
# Download the .crx once at build time so the container has no outbound
# dependency at run time. The inlined Python script strips the CRX3 header,
# unzips the payload, and injects the extension's original public key into
# manifest.json so Chrome loads it under the original extension id
# (fcoeoabgfenejglbffodgkkbkcdhcgfn) — that id is what the Claude Code CLI's
# native-messaging allow-list expects.
RUN mkdir -p /app/claude-in-chrome \
    && CRX_ID=fcoeoabgfenejglbffodgkkbkcdhcgfn \
    && wget --tries=3 -qO /tmp/claude.crx \
    "https://clients2.google.com/service/update2/crx?response=redirect&prodversion=131.0.0.0&acceptformat=crx2,crx3&x=id%3D${CRX_ID}%26installsource%3Dondemand%26uc" \
    && python3 - /tmp/claude.crx /app/claude-in-chrome <<'PYEOF' \
    && rm /tmp/claude.crx \
    && ls /app/claude-in-chrome/manifest.json
import base64, hashlib, io, json, struct, sys, zipfile
from pathlib import Path

crx_path = Path(sys.argv[1])
out_dir = Path(sys.argv[2])
data = crx_path.read_bytes()
assert data[:4] == b"Cr24", f"Not a CRX file: {data[:4]!r}"
version = struct.unpack("<I", data[4:8])[0]

def read_varint(buf, off):
    val, shift = 0, 0
    while True:
        b = buf[off]; off += 1
        val |= (b & 0x7F) << shift
        if not (b & 0x80):
            return val, off
        shift += 7

def fields(buf):
    off = 0
    while off < len(buf):
        tag, off = read_varint(buf, off)
        fn, wt = tag >> 3, tag & 7
        if wt == 0:
            v, off = read_varint(buf, off); yield fn, v, "var"
        elif wt == 2:
            ln, off = read_varint(buf, off)
            yield fn, buf[off:off+ln], "bytes"
            off += ln
        elif wt == 5:
            yield fn, buf[off:off+4], "f32"; off += 4
        elif wt == 1:
            yield fn, buf[off:off+8], "f64"; off += 8
        else:
            raise ValueError(f"bad wire type {wt}")

public_key = None
if version == 3:
    hdr_size = struct.unpack("<I", data[8:12])[0]
    hdr = data[12:12 + hdr_size]
    zip_start = 12 + hdr_size

    # CRX3 headers ship multiple sha256_with_rsa proofs (repeated field 2).
    # The first entry is typically the Chrome Web Store's signing key; the
    # developer's key — whose SHA256 prefix is the real extension id — is a
    # later entry. We resolve the tie by reading signed_header_data (field
    # 10000), deserializing its SignedData.crx_id (field 1), and picking the
    # public_key whose hash matches those 16 bytes.
    rsa_keys = []
    target_crx_id = None
    for fn, val, _ in fields(hdr):
        if fn == 2:
            for sfn, sval, _ in fields(val):
                if sfn == 1:
                    rsa_keys.append(sval)
                    break
        elif fn == 10000:
            for sfn, sval, _ in fields(val):
                if sfn == 1:
                    target_crx_id = sval
                    break

    if target_crx_id:
        for pk in rsa_keys:
            if hashlib.sha256(pk).digest()[:16] == target_crx_id:
                public_key = pk
                break
    if public_key is None and rsa_keys:
        # Fallback: no signed_header_data — use the last proof, which is more
        # likely to be the developer's key than the first (CWS re-sign).
        public_key = rsa_keys[-1]
elif version == 2:
    pk_len = struct.unpack("<I", data[8:12])[0]
    sg_len = struct.unpack("<I", data[12:16])[0]
    public_key = data[16:16 + pk_len]
    zip_start = 16 + pk_len + sg_len
else:
    raise SystemExit(f"Unknown CRX version: {version}")

out_dir.mkdir(parents=True, exist_ok=True)
zipfile.ZipFile(io.BytesIO(data[zip_start:])).extractall(out_dir)

if public_key:
    manifest_path = out_dir / "manifest.json"
    manifest = json.loads(manifest_path.read_text())
    manifest["key"] = base64.b64encode(public_key).decode()
    manifest_path.write_text(json.dumps(manifest, indent=2))
    digest = hashlib.sha256(public_key).digest()[:16]
    ext_id = "".join(chr(ord("a") + (b >> 4)) + chr(ord("a") + (b & 0xF)) for b in digest)
    print(f"Extracted CRX, extension id: {ext_id}")
else:
    print("WARN: no public key recovered — extension id will be path-derived.")
PYEOF

# Patch the unpacked extension to talk to our local fake bridge + skip the
# claude.ai OAuth preflight. Without a real claude.ai session the extension's
# `en()` connector aborts the moment `u()` (OAuth token fetch) or `h(o)`
# (user-id lookup) returns null — we rewrite those branches to fall through
# with placeholders, and redirect the bridge WebSocket URL to our fake on
# 127.0.0.1:4002. We also widen the manifest CSP connect-src so the browser
# does not block the ws:// connection to localhost.
RUN python3 - /app/claude-in-chrome <<'PYEOF'
import json, sys
from pathlib import Path

assets_dir = Path(sys.argv[1])
patches: list[str] = []


def patch_file(path):
    text = path.read_text()
    original = text
    # 1. Bridge URL — must run first, keeps the `${t}` template intact.
    for needle in ("wss://bridge.claudeusercontent.com",
                   "wss://bridge-staging.claudeusercontent.com"):
        if needle in text:
            text = text.replace(needle, "ws://127.0.0.1:4002", 1)
            patches.append(f"{path.name}: bridge URL")
    # 2. Neutralize wsApiBaseUrl for permission manager — forces HTTPS ws to
    # api.anthropic.com; we want it to fail fast so it does not hang.
    if '"wss://api.anthropic.com"' in text:
        text = text.replace('"wss://api.anthropic.com"',
                            '"ws://127.0.0.1:4001"', 1)
        patches.append(f"{path.name}: wsApiBaseUrl")
    # 3. Bypass OAuth null-return inside en().
    oauth_null = 'if(o=await u(),!o)return Na=!1,nn(),!1;'
    oauth_fix = 'if(o=await u(),!o)o="fake-oauth-token";'
    if oauth_null in text:
        text = text.replace(oauth_null, oauth_fix, 1)
        patches.append(f"{path.name}: OAuth null-return")
    userid_null = 'if(t=await h(o),!t)return Na=!1,nn(),!1;'
    userid_fix = 'if(t=await h(o),!t)t="clawbench-user";'
    if userid_null in text:
        text = text.replace(userid_null, userid_fix, 1)
        patches.append(f"{path.name}: userId null-return")
    if text != original:
        path.write_text(text)


for js in sorted(assets_dir.rglob("*.js")):
    patch_file(js)

# Broaden the extension's CSP so the browser lets us `new WebSocket(...)` to
# our local fake bridge + mock API. Without this the upgrade silently fails.
manifest_path = assets_dir / "manifest.json"
manifest = json.loads(manifest_path.read_text())
csp = manifest.get("content_security_policy")
if isinstance(csp, dict) and "extension_pages" in csp:
    pages = csp["extension_pages"]
    extra = " ws://127.0.0.1:4002 ws://localhost:4002 http://127.0.0.1:4001 http://localhost:4001"
    if "connect-src " in pages and "ws://127.0.0.1:4002" not in pages:
        pages = pages.replace("connect-src ", "connect-src" + extra + " ", 1)
        csp["extension_pages"] = pages
        manifest["content_security_policy"] = csp
        manifest_path.write_text(json.dumps(manifest, indent=2))
        patches.append("manifest.json CSP connect-src")

# Fail loudly if the bridge URL patch didn't match any file — silent skew in
# the extension's minified source would otherwise produce a confusing
# "Browser extension is not connected" at runtime.
if not any(p.endswith("bridge URL") for p in patches):
    raise SystemExit(
        "ERROR: extension patch 'bridge URL' did not match any JS file. "
        "The Claude in Chrome extension's minified source has likely "
        "changed — update the Dockerfile's extension-patch heredoc.")

PYEOF

# --- Native messaging host shim --------------------------------------------
# Edge spawns this shim when the Claude in Chrome extension calls
# `chrome.runtime.connectNative(...)`. The shim's stdio is the
# Chrome-framed JSON-RPC channel; the CLI's `--chrome-native-host` mode
# speaks that protocol natively. Two nuances:
#
#   1. The flag is `--chrome-native-host` (grep cli.js for argv[2]) — bare
#      `native-host` is parsed as a prompt.
#   2. Edge launches us with its own env, so we re-source
#      /tmp/claude-code-env.sh (written by the setup script) to pick up
#      ANTHROPIC_API_KEY + ANTHROPIC_BASE_URL. Without those the CLI bails
#      with "Not logged in · Please run /login".
RUN cat > /usr/local/bin/claude-native-host <<'EOF'
#!/bin/bash
if [ -f /tmp/claude-code-env.sh ]; then
    # shellcheck disable=SC1091
    source /tmp/claude-code-env.sh
fi
exec claude --chrome-native-host "$@"
EOF
RUN chmod +x /usr/local/bin/claude-native-host

# Install the descriptor at the system-wide path. Edge's per-user path
# ($HOME/.config/microsoft-edge/NativeMessagingHosts) is ignored when the
# browser is launched with a custom --user-data-dir — verified empirically
# with a DevTools-driven connectNative probe that returned "native messaging
# host not found" until we copied the JSON to /etc/opt/edge/. The system
# path always wins for both Edge Stable and Beta.
RUN mkdir -p /etc/opt/edge/native-messaging-hosts \
    && cat > /etc/opt/edge/native-messaging-hosts/com.anthropic.claude_code_browser_extension.json <<'EOF'
{
  "name": "com.anthropic.claude_code_browser_extension",
  "description": "Claude Code browser extension bridge",
  "path": "/usr/local/bin/claude-native-host",
  "type": "stdio",
  "allowed_origins": [
    "chrome-extension://fcoeoabgfenejglbffodgkkbkcdhcgfn/"
  ]
}
EOF

# --- Browser + extension selection ------------------------------------------
ENV BROWSER_BINARY=microsoft-edge-stable
ENV EXTRA_LOAD_EXTENSIONS=/app/claude-in-chrome

# --- Harness scripts --------------------------------------------------------
COPY src/harnesses/claude-code-chrome-extension/setup-claude-code-chrome-extension.sh /setup-claude-code-chrome-extension.sh
COPY src/harnesses/claude-code-chrome-extension/run-claude-code-chrome-extension.sh /run-harness.sh
RUN chmod +x /setup-claude-code-chrome-extension.sh /run-harness.sh
